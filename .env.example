# App
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://pfl:pfl_dev@localhost:5432/pfl
DATABASE_ECHO=false

# Security
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32_this_is_placeholder_unsafe
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# MFA
MFA_ISSUER=PFL Finance Credit AI

# CORS
CORS_ORIGINS=http://localhost:3000

# AWS / LocalStack (dev defaults; override for prod)
AWS_REGION=ap-south-1
AWS_S3_ENDPOINT_URL=http://localhost:4566
AWS_SQS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=pfl-cases-dev
SQS_INGESTION_QUEUE=pfl-ingestion-dev
SQS_INGESTION_DLQ=pfl-ingestion-dev-dlq
PRESIGNED_URL_EXPIRES_SECONDS=900
MAX_ZIP_SIZE_BYTES=104857600
DEV_AUTO_CREATE_AWS_RESOURCES=true

# M3 SES + worker
SES_SENDER=no-reply@pflfinance.com
SES_VERIFY_ON_STARTUP=true
WORKER_POLL_INTERVAL_SECONDS=20
WORKER_CONCURRENCY=1
APP_BASE_URL=http://localhost:8000

# M5 Anthropic / Decisioning
ANTHROPIC_API_KEY=sk-ant-...replace-me
ANTHROPIC_BASE_URL=
DECISIONING_ENABLED=false
DECISIONING_SHADOW_ONLY=true
DECISIONING_QUEUE_URL=http://localhost:4566/000000000000/pfl-decisioning-jobs
DECISIONING_DLQ_URL=http://localhost:4566/000000000000/pfl-decisioning-dlq
SQS_DECISIONING_QUEUE=pfl-decisioning-jobs
SQS_DECISIONING_DLQ=pfl-decisioning-dlq
